{
	"info": {
		"_postman_id": "resumeai-backend-001",
		"name": "ResumeAI Backend",
		"description": "Complete API collection for ResumeAI backend. Set `base_url` and `access_token` in collection or environment variables.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		},
		{
			"key": "resume_id",
			"value": "1"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Signup",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Alex Doe\",\n  \"email\": \"alex@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
						},
						"url": "{{base_url}}/auth/signup"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"  const json = pm.response.json();",
									"  pm.collectionVariables.set('access_token', json.access_token);",
									"  pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"alex@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
						},
						"url": "{{base_url}}/auth/login"
					}
				},
				{
					"name": "Refresh Tokens",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"  const json = pm.response.json();",
									"  pm.collectionVariables.set('access_token', json.access_token);",
									"  pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
						},
						"url": "{{base_url}}/auth/refresh"
					}
				},
				{
					"name": "Logout All",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": "{{base_url}}/auth/logout-all"
					}
				}
			]
		},
		{
			"name": "Profile",
			"item": [
				{
					"name": "Get Profile (me)",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/profile/me"
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Alex Doe\",\n  \"phone\": \"+1 555 555 5555\",\n  \"location\": \"New York, NY\",\n  \"linkedin_url\": \"https://linkedin.com/in/alex\",\n  \"portfolio_url\": \"https://alex.dev\"\n}"
						},
						"url": "{{base_url}}/profile/me"
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"old_password\": \"SecurePass123!\",\n  \"new_password\": \"NewSecurePass456!\",\n  \"confirm_password\": \"NewSecurePass456!\"\n}"
						},
						"url": "{{base_url}}/profile/change-password"
					}
				},
				{
					"name": "Sync Profile from Resume",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/profile/sync-from-resume/{{resume_id}}"

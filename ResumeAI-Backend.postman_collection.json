				},
				{
					"name": "Create from Upload (Start from scratch)",
					"request": {
						"method": "POST",
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "file", "type": "file", "src": ""}
							]
						},
						"url": "{{base_url}}/resumes/from-upload"
					}
				},
				{
					"name": "Build from Upload (Build upon existing)",
					"request": {
						"method": "PATCH",
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "file", "type": "file", "src": ""}
							]
						},
						"url": "{{base_url}}/resumes/{{resume_id}}/from-upload"
					}
				},
				{
					"name": "Parse Upload (Preview)",
					"request": {
						"method": "POST",
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "file", "type": "file", "src": ""}
							]
						},
						"url": "{{base_url}}/resumes/parse-upload"
					}
				},
				{
					"name": "List Resumes",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/resumes?limit=50&offset=0",
							"host": ["{{base_url}}"],
							"path": ["resumes"],
							"query": [
								{"key": "limit", "value": "50"},
								{"key": "offset", "value": "0"},
								{"key": "q", "value": "", "disabled": true}
							]
						}
					}
				},

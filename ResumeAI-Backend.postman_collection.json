					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Resume Title\",\n  \"status\": \"draft\"\n}"
						},
						"url": "{{base_url}}/resumes/{{resume_id}}"
					}
				},
				{
					"name": "Duplicate Resume",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/resumes/{{resume_id}}/duplicate"
					}
				},
				{
					"name": "Delete Resume",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/resumes/{{resume_id}}"
					}
				},
				{
					"name": "Get Content",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/resumes/{{resume_id}}/content",
							"host": ["{{base_url}}"],
							"path": ["resumes", "{{resume_id}}", "content"],
							"query": [
								{"key": "section", "value": "info", "disabled": true, "description": "info|experience|education|skills|summary|job_description|custom"}
							]
						}
					}
				},
				{
					"name": "Patch Content (info)",
					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"Alex Doe\",\n  \"email\": \"alex@example.com\",\n  \"phone\": \"+1 555 555 5555\",\n  \"location\": \"New York, NY\",\n  \"linkedin_url\": \"https://linkedin.com/in/alex\",\n  \"portfolio_url\": \"https://alex.dev\"\n}"
						},
						"url": "{{base_url}}/resumes/{{resume_id}}/content?section=info"
					}
				},
				{
					"name": "Patch Content (experience)",
					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "[\n  {\n    \"role\": \"Software Engineer\",\n    \"company\": \"Acme Inc\",\n    \"start_date\": \"2020\",\n    \"end_date\": \"2024\",\n    \"description\": \"Built scalable systems.\"\n  }\n]"
						},
						"url": "{{base_url}}/resumes/{{resume_id}}/content?section=experience"
					}
				},
				{
					"name": "Patch Content (skills)",
					"request": {
						"method": "PATCH",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "[\"Python\", \"FastAPI\", \"PostgreSQL\", \"React\"]"
						},
						"url": "{{base_url}}/resumes/{{resume_id}}/content?section=skills"
					}
				},
				{
					"name": "Get Sections Definition",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/resumes/sections/definition?section=info"
					}
				},
				{
					"name": "Save ATS Score (from AI)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"overall_score\": 86,\n  \"max_score\": 100,\n  \"category_scores\": {\n    \"keyword_match\": {\"label\": \"Keyword Match\", \"description\": \"Matched 41/50 role keywords.\", \"score\": 41, \"max\": 50},\n    \"contact_info\": {\"label\": \"Contact Info Completeness\", \"description\": \"Email, phone, LinkedIn present.\"},\n    \"readability\": {\"label\": \"Readability\", \"description\": \"Clear phrasing and action verbs.\"},\n    \"formatting\": {\"label\": \"Formatting & Structure\", \"description\": \"Consistent headings, bullet points, spacing.\"},\n    \"section_detection\": {\"label\": \"Section Detection\", \"description\": \"Experience, Education, Skills, Summary detected.\"},\n    \"ats_compatibility\": {\"label\": \"ATS Compatibility\", \"description\": \"Simple layout, parsable text.\"}\n  },\n  \"recommendations\": [\n    \"Add keyword \\\"Agile\\\" in Experience section\",\n    \"Consider a dedicated \\\"Skills\\\" header for better parsing\",\n    \"Replace images/icons with plain text for ATS\",\n    \"Use consistent date format (e.g., Jan 2022 - Present)\"\n  ]\n}"
						},
						"url": "{{base_url}}/resumes/{{resume_id}}/ats-score"
					}
				},
				{
					"name": "Get ATS Score",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/resumes/{{resume_id}}/ats-score"
					}
				}
			]
